@inherits LayoutComponentBase

<div class="home-layout">
    <header class="home-header">
        <nav class="home-nav">
            <a href="/" class="home-brand">Article management</a>
            <div class="home-nav-links">
                <AuthorizeView>
                    <Authorized>
                        <CartBadge @rendermode="@(new InteractiveServerRenderMode(prerender: false))" />
                        <details class="user-menu">
                            <summary>
                                <span class="bi bi-person-circle-home" aria-hidden="true"></span> @context.User.Identity?.Name
                            </summary>
                            <div class="user-menu-dropdown">
                                <form action="Account/Logout" method="post">
                                    <AntiforgeryToken />
                                    <input type="hidden" name="ReturnUrl" value="/" />
                                    <button type="submit" class="user-menu-logout">
                                        <span class="bi bi-box-arrow-right-home" aria-hidden="true"></span> Logout
                                    </button>
                                </form>
                            </div>
                        </details>
                    </Authorized>
                    <NotAuthorized>
                        <a href="Account/Login">Login</a>
                        <a href="Account/Register">Register</a>
                    </NotAuthorized>
                </AuthorizeView>
            </div>
        </nav>
    </header>

    <main class="home-main">
        @Body
    </main>
</div>