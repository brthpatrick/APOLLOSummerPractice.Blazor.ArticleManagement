@using SummerPractice2026Blazor.Components.Shared
@using SummerPractice2026Blazor.Repository.Entities
@using SummerPractice2026Blazor.Repository.Interfaces
@inject IArticleCategoryRepository articleCategoryRepository

<div class="category-filter">
  <Button Class="@GetButtonClass(null)"
          OnClick="@(() => SelectCategory(null))">
    All
  </Button>
  @foreach (var category in ArticleCategories)
  {
    <Button Class="@GetButtonClass(category.Id)"
            OnClick="@(() => SelectCategory(category.Id))">
      @category.Name
    </Button>
  }
</div>

@code {
  [Parameter]
  public EventCallback<Guid?> OnCategorySelected { get; set; }

  private IEnumerable<ArticleCategory> ArticleCategories { get; set; } = [];

  private Guid? SelectedCategoryId { get; set; }

  protected override async Task OnInitializedAsync()
  {
    ArticleCategories = await articleCategoryRepository.GetAllArticleCategories();
  }

  private async Task SelectCategory(Guid? categoryId)
  {
    SelectedCategoryId = categoryId;
    await OnCategorySelected.InvokeAsync(categoryId);
  }

  private string GetButtonClass(Guid? categoryId)
  {
    return SelectedCategoryId == categoryId
      ? "btn btn-primary"
      : "btn btn-secondary";
  }
}