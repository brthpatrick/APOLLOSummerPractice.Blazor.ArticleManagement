@page "/article"
@attribute [Authorize(Roles = CustomRoles.Role_Admin)]
@using Microsoft.AspNetCore.Authorization
@using SummerPractice2026Blazor.Constants
@using System.Globalization
@using Radzen
@using Radzen.Blazor
@using SummerPractice2026Blazor.Components.Shared
@using SummerPractice2026Blazor.Repository.Entities
@using SummerPractice2026Blazor.Repository.Interfaces
@inject IArticleRepository _articleRepository
@inject DialogService _dialogService
@inject NavigationManager _navigationManager
@rendermode @(new InteractiveServerRenderMode(prerender: false))

<PageTitle>Article List</PageTitle>

@if (IsLoading)
{
  <div class="loading-overlay">
    <img src="/images/loading.gif" alt="Loading" />
  </div>
}
else
{
  <div class="custom-card">
    <div class="custom-card-header">
      <h2 class="header-title">Article</h2>
      <Button OnClick="@(() => _navigationManager.NavigateTo("article/create"))" Class="btn btn-secondary">
        Add New Article
      </Button>
    </div>
    <div class="custom-card-body">
      @if (Articles.Any())
      {
        <RadzenDataGrid Data="@Articles" TItem="Article" class="custom-table">
          <Columns>
            <RadzenDataGridColumn TItem="Article" Property="Name" Title="Name" />
            <RadzenDataGridColumn TItem="Article" Title="Price">
              <Template Context="obj">
                @obj.Price.ToString("C", CultureInfo.GetCultureInfo("en-us"))
              </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="Article" Title="Special Tag">
              <Template Context="obj">
                <span class="custom-badge"> @obj.SpecialTag</span>
              </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="Article" Title="Article Category">
              <Template Context="obj">
                @obj.ArticleCategory.Name
              </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="Article" Sortable="false" Filterable="false" TextAlign="TextAlign.Right">
              <Template Context="obj">
                <Button Class="btn btn-primary" OnClick="@(() => _navigationManager.NavigateTo($"article/update/{obj.Id}"))">
                  Edit
                </Button>
                <Button Class="btn btn-danger" OnClick="@(() => HandleDelete(obj.Id))">
                  Delete
                </Button>
              </Template>
            </RadzenDataGridColumn>
          </Columns>
        </RadzenDataGrid>
      }
    </div>
  </div>

}
@code {
  private bool IsLoading;
  private IEnumerable<Article> Articles { get; set; } = [];

  protected override async Task OnInitializedAsync()
  {
    IsLoading = true;
    await LoadArticles();
    IsLoading = false;
  }

  private async Task LoadArticles()
  {
    Articles = await _articleRepository.GetAllArticlesAsync();
  }

  private async Task HandleDelete(Guid id)
  {
    var confirmed = await _dialogService.Confirm(
      "Are you sure you want to delete this article?",
      "Delete confirmation",
      new ConfirmOptions { OkButtonText = "Delete", CancelButtonText = "Cancel" });

    if (confirmed == true)
    {
      IsLoading = true;
      await _articleRepository.DeleteArticleAsync(id);
      await LoadArticles();
      IsLoading = false;
    }
  }
}