@page "/article-category"
@attribute [Authorize(Roles = CustomRoles.Role_Admin)]
@using Microsoft.AspNetCore.Authorization
@using SummerPractice2026Blazor.Constants
@using Repository.Interfaces;
@using Repository.Entities;
@using SummerPractice2026Blazor.Components.Shared
@inject IArticleCategoryRepository _articleCategoryRepository
@inject NavigationManager _navigationManager
@inject DialogService _dialogService
@rendermode @(new InteractiveServerRenderMode(prerender: false))

<PageTitle>Article Category List</PageTitle>

@if (isLoading)
{
  <div class="loading-overlay">
    <img src="/images/loading.gif" alt="Loading" />
  </div>
}
else
{
  <div class="custom-card">
    <div class="custom-card-header">
      <h2 class="header-title">Article Category</h2>
      <Button Class="btn btn-secondary"
              OnClick="@(() => _navigationManager.NavigateTo("article-category/create"))">
        Add New Category
      </Button>
    </div>
    <div class="custom-card-body">
      <RadzenDataGrid Data="@articleCategories" TItem="ArticleCategory" class="custom-table">
        <Columns>
          <RadzenDataGridColumn TItem="ArticleCategory" Property="Name" Title="Name" />
          <RadzenDataGridColumn TItem="ArticleCategory" TextAlign="TextAlign.Right">
            <Template Context="articleCategory">
              <Button OnClick="@(() => _navigationManager
                .NavigateTo($"article-category/update/{articleCategory.Id}"))">
                Edit
              </Button>
              <Button Class="btn btn-danger"
                      OnClick="@(() => DeleteCategory(articleCategory.Id))">
                Delete
              </Button>
            </Template>
          </RadzenDataGridColumn>
        </Columns>
      </RadzenDataGrid>
    </div>
  </div>
}

@code {
  private bool isLoading;
  private List<ArticleCategory> articleCategories;

  protected override async Task OnInitializedAsync()
  {
    isLoading = true;
    await LoadAllCategories();
    isLoading = false;
  }

  private async Task LoadAllCategories()
  {
    articleCategories = await _articleCategoryRepository.GetAllArticleCategories();
  }

  private async Task DeleteCategory(Guid categoryId)
  {
    var confirmed = await _dialogService
        .Confirm("Are you sure you want to delete this category?",
        "Confirm Delete",
        new ConfirmOptions { OkButtonText = "Yes", CancelButtonText = "No" });
    if (confirmed == true)
    {
      isLoading = true;
      await _articleCategoryRepository.DeleteArticleCategory(categoryId);
      // articleCategories.RemoveAll(c => c.Id == categoryId);
      await LoadAllCategories();
      isLoading = false;
    }
  }
}
